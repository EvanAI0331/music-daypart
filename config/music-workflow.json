    {
      "id": "work",
      "enabled": true,
      "start": "13:30",
      "end": "17:30",
      "intent": "咖啡",
      "keywords": [
        "悠闲",
        "最新",
        "热门"
      ],
      "negativeKeywords": []
    },
    {
      "id": "evening",
      "enabled": true,
      "start": "17:30",
      "end": "22:30",
      "intent": "放松、旋律感、晚间恢复",
      "keywords": [],
      "negativeKeywords": []
    },
    {
      "id": "late",
      "enabled": true,
      "start": "22:30",
      "end": "07:30",
